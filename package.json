{
  "name": "mr",
  "version": "0.4.0",
  "description": "CNB merge request helper CLI.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JUNERDD/mr.git"
  },
  "keywords": [
    "cnb",
    "git",
    "merge-request",
    "cli"
  ],
  "files": [
    "dist",
    "README.md",
    "install.sh",
    "uninstall.sh"
  ],
  "main": "./dist/index.js",
  "bin": {
    "mr": "./dist/index.js",
    "mrm": "./dist/index.js",
    "mrt": "./dist/index.js",
    "mrp": "./dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "npm run typecheck && npm test && npm run build && node --check dist/index.js",
    "pack:release": "bash scripts/package-release.sh",
    "prepack": "npm run build",
    "preversion": "npm run check",
    "release:major": "npm version major -m \"chore: release v%s\"",
    "release:minor": "npm version minor -m \"chore: release v%s\"",
    "release:patch": "npm version patch -m \"chore: release v%s\"",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "execa": "^9.6.1",
    "ink": "^7.0.2",
    "ora": "^9.4.0",
    "pastel": "^4.0.1",
    "picocolors": "^1.1.1",
    "react": "^19.2.6",
    "react-devtools-core": "^6.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  }
}
